# sdr-research-oss configuration
# Copy to .env and fill in your values. .env is .gitignore'd.

# ─── Station identity ──────────────────────────────────────────────────────
STATION_CALLSIGN=N0CALL
STATION_GRID=AA00aa
STATION_LAT=0.0
STATION_LON=0.0
OPERATOR_EMAIL=operator@example.com

# ─── Database ──────────────────────────────────────────────────────────────
POSTGRES_USER=sdr_viewer
POSTGRES_PASSWORD=change-me-please
POSTGRES_DB=sdr_viewer
DATABASE_URL=postgresql://sdr_viewer:change-me-please@postgres:5432/sdr_viewer

# ─── API ───────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
CACHE_PATH=/tmp/sdr-viewer-cache
TEXT_BASE_PATH=/data/text
HF_TEXT_BASE_PATH=/data/hf/text

# ─── RepeaterBook (US/CA repeater directory) ───────────────────────────────
# Optional. Full setup walkthrough: docs/repeaterbook-setup.md
# Get a token at https://www.repeaterbook.com/api/token_request.php
REPEATERBOOK_ENABLED=false
REPEATERBOOK_API_KEY=
# User-Agent MUST match the value RepeaterBook approved with your token.
REPEATERBOOK_USER_AGENT=sdr-research-oss/1.0 (operator@example.com)
REPEATERBOOK_EMAIL=operator@example.com
REPEATERBOOK_LATITUDE=0.0
REPEATERBOOK_LONGITUDE=0.0
REPEATERBOOK_RADIUS_MILES=75
# Comma-separated US/Canadian state/province codes to sync. The radius search
# combines with this list (only repeaters in these states AND within radius).
# Examples: OH,IN,KY  |  CA,NV,AZ  |  ON,QC  (Canadian provinces)
# Leave empty to skip the state filter (fetches all in radius).
REPEATERBOOK_STATES=
REPEATERBOOK_SYNC_HOURS=24

# ─── Alerting (optional webhook on callsign / keyword match) ───────────────
ALERT_CALLSIGNS=
ALERT_KEYWORDS=
ALERT_WEBHOOK_URL=

# ─── SDR hardware ──────────────────────────────────────────────────────────
# See docs/hardware-matrix.md for OSMOSDR_ARGS strings per device.
# Examples:
#   RTL-SDR via rtl_tcp:  rtl_tcp=rtl-tcp:1234
#   Airspy direct USB:    airspy=0
#   Airspy via SoapyRemote: soapy=0,driver=remote,remote=tcp://host:55132,remote:driver=airspy
#   RX888 MkII direct:    driver=SDDC
OSMOSDR_ARGS=rtl_tcp=rtl-tcp:1234
SAMPLE_RATE=2400000
DWELL_CENTER_HZ=146000000
FIXED_MONITOR_HZ=146520000
SCAN_CENTERS=[]
DWELL_SEC=60
SCAN_SEC=5
RF_GAIN=40
PPM_CORRECTION=0

# ─── Detector / squelch ────────────────────────────────────────────────────
RF_SQUELCH_DB=-50
SQUELCH_OPEN_DB=-50
SQUELCH_CLOSE_DB=-55
ENERGY_THRESH_DB=10
FM_RECORD_BANDS_HZ=144300000-148000000,150000000-162000000,222000000-225000000,433000000-450000000
CW_RECORD_BANDS_HZ=144000000-144150000,432000000-432100000
MIN_REC_SEC=0.5
MAX_REC_SEC=120
TAIL_SEC=1.5
NUM_DYN_FM=8
NUM_DYN_CW=4
NUM_DYN_ACARS=0
SLOT_RECYCLE_SEC=300

# ─── Whisper transcription (optional) ──────────────────────────────────────
WHISPER_ENABLED=false
WHISPER_MODEL=base.en
WHISPER_DEVICE=cpu
# Set to 'cuda' if you have NVIDIA GPU + nvidia-container-toolkit

# ─── Ollama tagging (optional) ─────────────────────────────────────────────
# Auto-tags voice transcripts with topic / intent / sentiment hints using a
# local LLM. Full setup walkthrough: docs/ollama-setup.md
OLLAMA_ENABLED=false
OLLAMA_URL=http://ollama:11434
# Any model your Ollama instance has pulled. Smaller = faster.
# Tested: llama3.1:8b (good quality), llama3.2:3b (faster), qwen2.5:3b (smallest viable)
OLLAMA_MODEL=llama3.1:8b
# Per-request timeout (seconds). Bump if running on CPU or a slow GPU.
OLLAMA_TIMEOUT_SECONDS=20
# Max number of tags Ollama may emit per recording.
OLLAMA_MAX_TAGS=8
# Cap calls per indexer pass (prevents runaway when many new recordings land).
OLLAMA_MAX_PER_CYCLE=40

# ─── Image tags (override to pull your own builds) ─────────────────────────
API_IMAGE=ghcr.io/w3rdw/sdr-research-api:latest
UI_IMAGE=ghcr.io/w3rdw/sdr-research-ui:latest
UNIFIED_SDR_IMAGE=ghcr.io/w3rdw/sdr-research-unified-sdr:latest
